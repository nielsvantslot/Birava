# db-test's docker-network hostname, not the host-mapped 5434 port — this
# file is loaded by `npm run test:integration` executed *inside* the
# birava-app container (docker exec birava-app ...), which reaches other
# compose services by service name, not localhost. Host-side tools (e.g. a
# one-off `psql`) should use localhost:5434 instead.
DATABASE_URL="postgresql://birava:birava@db-test:5432/birava_test?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3001"
