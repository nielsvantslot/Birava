generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(uuid()) @db.Uuid
  email                String                 @unique
  username             String                 @unique
  passwordHash         String
  avatarUrl            String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime               @default(now()) @db.Timestamptz(6)
  beerEntries          BeerEntry[]
  ownedGroups          Group[]                @relation("GroupOwner")
  groupMemberships     GroupMember[]
  follows              Follow[]               @relation("FollowFollower")
  followedBy           Follow[]               @relation("FollowFollowing")
  sessions             Session[]
  proosts              Proost[]
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String @db.Uuid
  sessionToken String   @unique
  expiresAt    DateTime @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Group {
  id         String        @id @default(uuid()) @db.Uuid
  name       String
  inviteCode String        @unique
  ownerId    String        @db.Uuid
  createdAt  DateTime      @default(now()) @db.Timestamptz(6)
  owner      User          @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members    GroupMember[]
  beerEntries BeerEntry[]

  @@index([ownerId])
}

model GroupMember {
  groupId   String   @db.Uuid
  userId    String   @db.Uuid
  joinedAt  DateTime @default(now()) @db.Timestamptz(6)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model BeerEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  groupId   String?  @db.Uuid
  beerName  String?
  brewery   String?
  style     String?
  drinkType String   @default("Beer")
  amount    Decimal  @default(1) @db.Decimal(10, 2)
  rating    Int?
  venue     String?
  lat       Decimal? @db.Decimal(9, 6)
  lng       Decimal? @db.Decimal(9, 6)
  notes     String?
  photoUrl  String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  proosts   Proost[]

  @@index([userId])
  @@index([groupId])
  @@index([createdAt(sort: Desc)])
}

/// A "proost" (kudos) on a session, keyed by the session's anchor
/// check-in — the session id is its first check-in's id.
model Proost {
  entryId   String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  entry     BeerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([entryId, userId])
  @@index([entryId])
}

model Follow {
  followerId  String   @db.Uuid
  followingId String   @db.Uuid
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  follower    User     @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}